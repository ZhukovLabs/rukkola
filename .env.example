# ===========================
# MongoDB
# ===========================
MONGODB_URI=mongodb://admin:secret@mongodb:27017/rukkola?authSource=admin

# ===========================
# Backend (NestJS)
# ===========================
# Place in root .env.local (NestJS ConfigModule reads from monorepo root)

# JWT secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# Backend port
BACKEND_PORT=4000

# hCaptcha (server-side secret)
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key

# MinIO Storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rukkola
MINIO_USE_SSL=false

# ===========================
# Frontend (Next.js)
# ===========================
# Place in packages/frontend/.env.local (Next.js reads from its own directory)

# Internal API URL (server-side requests, service-to-service)
INTERNAL_API_URL=http://backend:4000/api

# Base URL for SEO metadata
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# hCaptcha (client-side site key)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key
